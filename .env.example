# Сборка: полный URL поиска на hh.ru = VITE_HH_SEARCH_BASE_URL + "?" + query из API (строка после ?).
# По умолчанию в коде: https://hh.ru/search/vacancy
# VITE_HH_SEARCH_BASE_URL=https://hh.ru/search/vacancy

# --- API (axios): пустые значения — тот же origin (Docker nginx или proxy ниже в dev) ---
VITE_SETTINGS_MANAGER_BASE_URL=
VITE_JOB_POSTINGS_CRUD_BASE_URL=
VITE_JOB_POSTINGS_EVALUATOR_BASE_URL=
VITE_ORCHESTRATION_CONDUCTOR_BASE_URL=
VITE_ORCHESTRATION_SCHEDULER_BASE_URL=
VITE_ORCHESTRATION_ASYNC_JOBS_CRUD_BASE_URL=
# Пусто = same-origin, nginx (Docker) и Vite proxy префикс `/orchestration-conductor` → orchestration-conductor:8080.
# Пусто = same-origin, префикс `/orchestration-scheduler` → orchestration-scheduler:8080.
# Пусто = same-origin, префикс `/orchestration-async-jobs-crud` → orchestration-async-jobs-crud:8080.

# --- Только dev (vite.config): куда проксировать при пустых VITE_* выше ---
# По умолчанию 8080 = settings-manager, 8081 = job-postings-crud на localhost.
# VITE_DEV_PROXY_SETTINGS_MANAGER=http://127.0.0.1:8080
# VITE_DEV_PROXY_JOB_POSTINGS_CRUD=http://127.0.0.1:8081
# По умолчанию в vite.config: 8082 (job-postings-evaluator).
# VITE_DEV_PROXY_JOB_POSTINGS_EVALUATOR=http://127.0.0.1:8082
# По умолчанию в vite.config: 8084 (orchestration-conductor, см. OpenAPI servers).
# VITE_DEV_PROXY_ORCHESTRATION_CONDUCTOR=http://127.0.0.1:8084
# По умолчанию в vite.config: 8083 (orchestration-scheduler).
# VITE_DEV_PROXY_ORCHESTRATION_SCHEDULER=http://127.0.0.1:8083
# По умолчанию в vite.config: 8085 (orchestration-async-jobs-crud).
# VITE_DEV_PROXY_ORCHESTRATION_ASYNC_JOBS_CRUD=http://127.0.0.1:8085

# Без Vite proxy: задайте полные URL бэкендов (нужен CORS на API или тот же порт).
# VITE_SETTINGS_MANAGER_BASE_URL=http://localhost:8080
# VITE_JOB_POSTINGS_CRUD_BASE_URL=http://localhost:8081
# VITE_JOB_POSTINGS_EVALUATOR_BASE_URL=http://localhost:8082
